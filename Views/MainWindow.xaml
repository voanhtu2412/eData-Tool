<Window x:Class="TaxCodeCollector.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="THub - Template-based Web Scraper"
        Icon="/icon.png"
        Height="820"
        Width="1280"
        MinHeight="680"
        MinWidth="1060"
        Background="{StaticResource PinkLightestBrush}">

    <!-- All resources are defined globally in Theme.xaml -->

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="/logo.png" Height="40" Margin="0,0,12,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
            </StackPanel>
        </DockPanel>

        <!-- Content Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="520" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Template Fields -->
            <Border Grid.Column="0"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource PinkLightBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="200" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Template Fields"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Mỗi field gồm FieldName, CssSelector, XPath và SampleValue."
                                   Style="{StaticResource SubtitleText}"
                                   Margin="0,4,0,12"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <DataGrid x:Name="TemplatesGrid"
                               Grid.Row="1"
                               AutoGenerateColumns="False"
                               CanUserAddRows="False"
                               HeadersVisibility="Column"
                               ItemsSource="{Binding Templates}"
                               SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                               MouseDoubleClick="TemplatesGrid_MouseDoubleClick"
                               Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"
                                                Binding="{Binding OrderIndex}"
                                                Width="44" />
                            <DataGridTextColumn Header="FieldName"
                                                Binding="{Binding FieldName, UpdateSourceTrigger=PropertyChanged}"
                                                Width="*" />
                            <DataGridTextColumn Header="SampleValue"
                                                Binding="{Binding SampleValue, UpdateSourceTrigger=PropertyChanged}"
                                                Width="220" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Left Panel Control Inputs and Buttons -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <!-- Row 0: Pick URL Label -->
                        <TextBlock Grid.Row="0" Text="URL dùng khi Pick Element" Style="{StaticResource SubtitleText}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        
                        <!-- Row 1: Pick URL TextBox + Pick Element Button -->
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding PickUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center"
                                     ToolTip="Nhập URL trang chi tiết công ty để pick selector. Nếu trống sẽ dùng URL danh sách." />
                            <Button Grid.Column="1" Content="Pick Element"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding PickElementCommand}"
                                    VerticalAlignment="Center"
                                    Margin="0"
                                    MinWidth="110"/>
                        </Grid>
                        
                        <!-- Row 2: Management Buttons (Add Field, Remove, Save Template) -->
                        <UniformGrid Grid.Row="2" Columns="3">
                            <Button Content="Add Field"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding AddFieldCommand}"
                                    Margin="0,0,8,0" />
                            <Button Content="Remove"
                                    Style="{StaticResource DangerButton}"
                                    Command="{Binding RemoveFieldCommand}"
                                    Margin="0,0,8,0" />
                            <Button Content="Save Template"
                                    Style="{StaticResource SuccessButton}"
                                    Command="{Binding SaveTemplateCommand}"
                                    Margin="0" />
                        </UniformGrid>
                    </Grid>

                    <GroupBox Grid.Row="3"
                               Header="Log trạng thái"
                               Margin="0,12,0,0">
                        <ListBox ItemsSource="{Binding Logs}"
                                 Style="{StaticResource LogListBoxStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,1" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>
                </Grid>
            </Border>

            <!-- Right Panel: Scraper Settings & Results -->
            <Border Grid.Column="2"
                    Background="#FFFFFF"
                    BorderBrush="{StaticResource PinkLightBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Row 0: Title and Action Buttons -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Cấu hình Scraper &amp; URL danh sách"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Start Crawl"
                                        Style="{StaticResource SuccessButton}"
                                        Command="{Binding StartCrawlCommand}"
                                        Margin="0,0,8,0"
                                        MinWidth="110" />
                                <Button Content="Stop Crawl"
                                        Style="{StaticResource DangerButton}"
                                        Command="{Binding StopCrawlCommand}"
                                        Margin="0,0,8,0"
                                        MinWidth="110" />
                                <Button Content="Export Excel"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ExportExcelCommand}"
                                        Margin="0"
                                        MinWidth="110" />
                            </StackPanel>
                        </Grid>
                        
                        <!-- Row 1: Settings Inputs -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>

                            <!-- Col 0: URL danh sách -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="URL danh sách công ty" Style="{StaticResource SubtitleText}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding ListUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0"
                                         ToolTip="Ví dụ: trang danh sách kết quả tìm kiếm hoặc danh sách công ty trên website mã số thuế." />
                            </StackPanel>

                            <!-- Col 2: URL trang 2 -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="URL trang 2 / trang tiếp theo" Style="{StaticResource SubtitleText}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding NextPageUrl, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0"
                                         ToolTip="Copy URL trang 2 vào đây. Tool sẽ tự đoán trang 3, 4... theo cấu trúc URL." />
                            </StackPanel>

                            <!-- Col 4: Số trang -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Số trang" Style="{StaticResource SubtitleText}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding MaxPagesToCrawl, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0"
                                         ToolTip="Nhập số trang danh sách muốn lọc. Mặc định là 1 trang." />
                            </StackPanel>

                            <!-- Col 6: Số công ty/trang -->
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="Số cty / trang" Style="{StaticResource SubtitleText}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding MaxCompaniesPerPage, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0"
                                         ToolTip="Nhập số lượng công ty hiển thị trên mỗi trang danh sách. Mặc định là 30." />
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <DataGrid x:Name="ResultsGrid"
                               Grid.Row="1"
                               ItemsSource="{Binding Results}"
                               AutoGenerateColumns="False"
                               IsReadOnly="True"
                               CanUserAddRows="False"
                               EnableRowVirtualization="True"
                               EnableColumnVirtualization="True"
                               HeadersVisibility="Column"
                               GridLinesVisibility="Horizontal" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
